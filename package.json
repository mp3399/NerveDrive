{
  "name": "vitalscope",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Privacy-first, in-browser Apple Health analytics. Upload your export ZIP, get a premium health intelligence dashboard. Your data never leaves your device.",
  "license": "MIT",
  "homepage": "https://github.com/your-username/vitalscope",
  "scripts": {
